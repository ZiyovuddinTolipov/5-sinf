{
  "expo": {
    "name": "5-Sinf",
    "slug": "5-sinf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sinf5",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D89EF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sinf5.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D89EF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sinf5.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "apiUrl": "https://admin-production-c751.up.railway.app",
      "eas": {
        "projectId": "2df3dd8c-efd5-4961-b8a6-61f2ae041d67"
      }
    },
    "owner": "tolipov"
  }
}
