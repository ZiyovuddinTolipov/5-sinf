{
  "expo": {
    "name": "5-Sinf",
    "slug": "5-sinf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "sinf5",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sinf5.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D89EF"
      },
      "package": "com.sinf5.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#2D89EF"
        }
      ]
    ],
    "extra": {
      "router": {},
      "apiUrl": "https://admin-production-c751.up.railway.app",
      "eas": {
        "projectId": "2008a9f9-06da-4845-b82d-71f7def25365"
      }
    },
    "owner": "tolipov123"
  }
}
